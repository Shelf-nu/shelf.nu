{
  "name": "@shelf/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "echo 'No build step needed — types are source TypeScript'",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0"
  },
  "devDependencies": {
    "@shelf/typescript-config": "workspace:*",
    "@types/node": "^22.19.13",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^7.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
