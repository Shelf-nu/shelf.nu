# Maestro E2E Test Environment Variables
# Copy this file to test.env and fill in real values
# test.env is gitignored — never commit credentials

# Auth credentials for the primary test user
SHELF_TEST_EMAIL=test@example.com
SHELF_TEST_PASSWORD=your-password-here

# Known entity IDs for deterministic tests
# These must exist in the test account's organization
SHELF_TEST_ASSET_ID=clxxxxxxxxxxxxxxxxxxxxxx
SHELF_TEST_BOOKING_ID=clxxxxxxxxxxxxxxxxxxxxxx
SHELF_TEST_AUDIT_ID=clxxxxxxxxxxxxxxxxxxxxxx
SHELF_TEST_QR_ID=abcdefghij

# Scanner / booking / kit QR codes for scan-driven flows
SHELF_TEST_ASSET_QR_ID=abcdefghij
SHELF_TEST_KIT_QR_ID=klmnopqrst
SHELF_TEST_KIT_MEMBER_QR_ID=uvwxyz0123
SHELF_TEST_OUTSIDER_QR_ID=zyxwvutsrq

# Audit SAM / sequential-ID flow (audits/02-scan-sam-id.yaml)
# SHELF_TEST_SAM_ID MUST be lowercase (e.g. "sam-0001") so the test actually
# exercises the resolver's trim + uppercase normalization before it matches
# Asset.sequentialId. SHELF_TEST_SAM_TITLE is a regex fragment of the asset's
# title used to confirm the scan resolved.
SHELF_TEST_SAM_ID=sam-0001
SHELF_TEST_SAM_TITLE=Some Asset Title
SHELF_TEST_AUDIT_NAME=Your Audit Name

# (Optional) Known barcode value for barcode scanning tests
# Must be a barcode linked to an asset in the test org with barcodesEnabled: true
# SHELF_TEST_BARCODE_VALUE=MACBOOK-001

# (Optional) Second user for multi-role tests
# SHELF_TEST_VIEWER_EMAIL=viewer@example.com
# SHELF_TEST_VIEWER_PASSWORD=viewer-password
