<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      Universal Links: must mirror app.json `ios.associatedDomains`. The native
      project is checked in and built with `expo run:ios` (no prebuild), so the
      entitlement has to live here too, or the binary ships without
      `com.apple.developer.associated-domains` and iOS never verifies the AASA.
    -->
    <key>com.apple.developer.associated-domains</key>
    <array>
      <string>applinks:app.shelf.nu</string>
    </array>
  </dict>
</plist>